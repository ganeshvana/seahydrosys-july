<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hr_employee_form_inherited" model="ir.ui.view">
            <field name="name">hr.employee.form</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
           
            <xpath expr="//field[@name='address_home_id']" position="after">
                    <field name="current_address" widget="res_partner_many2one"
                        context="{'show_address': 1}"
                        options='{"always_reload": True}' />
            </xpath>
        </field>
    </record>
    <record id="view_hr_employee" model="ir.ui.view">
            <field name="name">hr.employee.inherit</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/sheet/div/field[@name='category_ids']" position="attributes">
                    <attribute name="options">{'color_field': 'color','always_reload': True, 'no_create_edit': True, 'no_create': True, 'no_open': True}</attribute>
                </xpath>
            </field>
        </record>

        
        
        <record id="view_hr_employee_kanban" model="ir.ui.view">
            <field name="name">hr.employee.kanban.inherit</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.hr_kanban_view_employees"/>
            <field name="arch" type="xml">
                <xpath expr="//li[field/@name='work_phone']" position="attributes">
                    <li t-if="record.work_phone.raw_value" class="o_force_ltr">
                        <attribute name="invisible">True</attribute>
                    </li>
                </xpath>                
            </field>
        </record>

    <!-- Contract -->
    <record id="hr_contract_form_inherited" model="ir.ui.view">
            <field name="name">hr.contract.form</field>
            <field name="model">hr.contract</field>
            <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
            <field name="arch" type="xml">
           
            <xpath expr="//field[@name='hr_responsible_id']" position="after">
                     <field name="years_of_experience" />
            </xpath>
        </field>
    </record>


    </data>
</odoo>
