<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hr_employee_form_inherited" model="ir.ui.view">
            <field name="name">hr.employee.form</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
           
            <xpath expr="//field[@name='address_home_id']" position="after">
                    <field name="current_address" widget="res_partner_many2one"
                        context="{'show_address': 1}"
                        options='{"always_reload": True}' />
            </xpath>
        </field>
    </record>
    <record id="hr_employee_kanban_inherited" model="ir.ui.view">
            <field name="name">hr.employee.kanban</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.hr_kanban_view_employees"/>
            <field name="arch" type="xml">
           
            <xpath expr="//field[@name='work_phone']" position="replace">
                    <li  class="o_force_ltr"><field name="mobile_phone"/></li>
                    <!-- t-if="record.mobile_phone" -->
            </xpath>
        </field>
    </record>
    <!-- Contract -->
